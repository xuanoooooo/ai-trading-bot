# 示例 .env 文件（不要提交真实密钥到代码库）
# Example .env file (DO NOT commit real keys to repository)
# 将此文件复制为 .env 并填写真实值（并确保 .env 在 .gitignore 中被忽略）
# Copy this file to .env and fill in real values (ensure .env is in .gitignore)

# ==================== 币安 API / Binance API ====================
BINANCE_API_KEY=your_binance_api_key_here
BINANCE_SECRET=your_binance_secret_here

# ==================== OpenAI 兼容 API 服务 / OpenAI-compatible API Service ====================
# 选择一个服务商并相应配置 / Choose one provider and configure accordingly:

# 选项 1: DeepSeek（推荐，性价比高）/ Option 1: DeepSeek (Recommended, cost-effective)
OPENAI_API_KEY=your_deepseek_api_key
OPENAI_BASE_URL=https://api.deepseek.com
OPENAI_MODEL_NAME=deepseek-chat

# 选项 2: SiliconFlow / Option 2: SiliconFlow
# OPENAI_API_KEY=your_siliconflow_api_key
# OPENAI_BASE_URL=https://api.siliconflow.cn/v1
# OPENAI_MODEL_NAME=deepseek-ai/DeepSeek-V2.5

# 选项 3: Groq / Option 3: Groq
# OPENAI_API_KEY=your_groq_api_key
# OPENAI_BASE_URL=https://api.groq.com/openai/v1
# OPENAI_MODEL_NAME=llama-3.1-70b-versatile

# 选项 4: OpenAI / Option 4: OpenAI
# OPENAI_API_KEY=your_openai_api_key
# OPENAI_BASE_URL=https://api.openai.com/v1
# OPENAI_MODEL_NAME=gpt-4o

# ==================== 其他可选配置 / Other Optional Configurations ====================
# LOG_LEVEL=INFO
# TZ=UTC
